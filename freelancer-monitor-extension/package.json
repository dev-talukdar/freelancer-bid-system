{
  "name": "freelancer-monitor-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "vite --mode development",
    "build": "vite build --mode production && node scripts/copy-manifest.mjs",
    "build:local": "vite build --mode development && node scripts/copy-manifest.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": { "react": "^19.2.1", "react-dom": "^19.2.1", "zod": "^4.1.13" },
  "devDependencies": {
    "@types/chrome": "^0.1.31", "@types/node": "^24.10.1",
    "@types/react": "^19.2.7", "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1", "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6", "tailwindcss": "^3.4.18", "typescript": "^5.9.3",
    "vite": "^7.2.4", "vitest": "^4.0.14"
  }
}
