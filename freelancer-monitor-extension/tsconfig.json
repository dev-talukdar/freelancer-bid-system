{
  "compilerOptions": {
    "target": "ES2022", "useDefineForClassFields": true, "module": "ESNext",
    "moduleResolution": "Bundler", "jsx": "react-jsx", "strict": true,
    "noEmit": true, "resolveJsonModule": true, "isolatedModules": true,
    "esModuleInterop": true, "skipLibCheck": true,
    "types": ["chrome", "vite/client", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts"],
  "exclude": ["dist", "node_modules", "coverage"]
}
