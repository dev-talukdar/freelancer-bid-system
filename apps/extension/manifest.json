{
  "manifest_version": 3,
  "name": "Freelancer Project Monitor",
  "version": "0.1.0",
  "description": "Freelancer.com project monitoring alerts backed by a private API.",
  "permissions": ["alarms", "notifications", "storage", "tabs", "offscreen"],
  "host_permissions": ["https://api.enaema.net/*", "http://127.0.0.1:4300/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "sw.js",
    "type": "module"
  }
}
