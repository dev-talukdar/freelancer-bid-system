{
  "name": "@fbs/extension",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b --force && vite build && node scripts/copy-manifest.mjs",
    "typecheck": "tsc -b --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fbs/shared": "0.1.0",
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/chrome": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "tailwindcss": "^3.4.17",
    "typescript": "latest",
    "vitest": "latest",
    "@types/node": "latest",
    "postcss": "latest",
    "autoprefixer": "latest"
  }
}
